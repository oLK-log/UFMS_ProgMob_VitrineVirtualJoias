<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <TextView
        android:id="@+id/txtTituloAbaPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="25dp"
        android:text="Meu Perfil"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:background="#FFFFFF"
        android:elevation="4dp" />

    <LinearLayout
        android:id="@+id/layoutDadosAbaPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txtTituloAbaPerfil"
        android:layout_marginTop="50dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardCornerRadius="70dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:id="@+id/imgAbaPerfil"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/txtNomeAbaPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome do Usuário"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#212121" />

        <TextView
            android:id="@+id/txtTipoPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Usuário"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSairSessao"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:text="@string/btn_sair"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF" />
</RelativeLayout>